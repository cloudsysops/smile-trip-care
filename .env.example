# =============================================================================
# Nebula Smile — environment variables
# Copy to .env.local and set values. Never commit .env.local.
# See docs/LOCAL_SETUP.md and docs/ENV_Y_STRIPE.md.
# =============================================================================

# -----------------------------------------------------------------------------
# App (Next.js)
# -----------------------------------------------------------------------------
COMMIT_SHA=local-dev

# -----------------------------------------------------------------------------
# Supabase (required for app)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: only for running migrations/seeds from your machine (npm run db:migrate)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Stripe (required for payments)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_123
STRIPE_SECRET_KEY=sk_test_123
STRIPE_WEBHOOK_SECRET=whsec_123

# -----------------------------------------------------------------------------
# OpenAI (optional — AI features)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# Vercel (optional — set in Vercel Dashboard for deploys; not needed locally)
# -----------------------------------------------------------------------------
# VERCEL_URL, VERCEL_ENV are set automatically by Vercel at build/runtime.

# -----------------------------------------------------------------------------
# Automation / workers (optional)
# -----------------------------------------------------------------------------
AUTOMATION_CRON_SECRET=replace-with-strong-random-secret
CRON_SECRET=replace-with-strong-random-secret

# -----------------------------------------------------------------------------
# Rate limiting (optional — default: memory; production: upstash)
# -----------------------------------------------------------------------------
RATE_LIMIT_PROVIDER=memory
# UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# Outbound (optional — email / WhatsApp)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_123
OUTBOUND_EMAIL_FROM=Nebula Smile <noreply@your-domain.com>
OUTBOUND_WHATSAPP_API_URL=https://api.your-whatsapp-provider.com/send
OUTBOUND_WHATSAPP_API_TOKEN=your-whatsapp-provider-token
NEXT_PUBLIC_WHATSAPP_NUMBER=573001234567

# -----------------------------------------------------------------------------
# Kafka (optional — see docs/KAFKA_LOCAL_SETUP.md)
# -----------------------------------------------------------------------------
# KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
# KAFKA_CLIENT_ID=nebula-smile

# -----------------------------------------------------------------------------
# Sentry (optional — error monitoring; add when integrating)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN= (only if needed for client-side; prefer server-only)
# SENTRY_AUTH_TOKEN= (for uploads; use in CI or server only)

# -----------------------------------------------------------------------------
# GitHub (optional — CI uses GitHub Actions; no local env needed for basic dev)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN is set in Actions; not in .env.local.

# -----------------------------------------------------------------------------
# Terraform (optional — only when provisioning infra; use CI or local env)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, etc. — not in .env.example for security.
