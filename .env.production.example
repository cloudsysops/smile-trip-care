# Production environment.
# Copy to .env.production in your deployment platform secret manager.

# Public
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_123

# Server
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
STRIPE_SECRET_KEY=sk_live_123
STRIPE_WEBHOOK_SECRET=whsec_prod_123
OPENAI_API_KEY=sk-production-placeholder
OPENAI_MODEL=gpt-4.1-mini

# Automation
AUTOMATION_CRON_SECRET=replace-with-strong-random-secret
CRON_SECRET=replace-with-strong-random-secret

# Optional outbound providers
RESEND_API_KEY=re_prod_123
OUTBOUND_EMAIL_FROM=Nebula Smile <noreply@your-domain.com>
OUTBOUND_WHATSAPP_API_URL=https://api.whatsapp-provider.com/send
OUTBOUND_WHATSAPP_API_TOKEN=production-whatsapp-token

# Optional metadata and infra
COMMIT_SHA=release-sha
RATE_LIMIT_PROVIDER=upstash
UPSTASH_REDIS_REST_URL=https://your-production-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-production-upstash-token
