# Staging environment.
# Copy to .env.staging in your deployment platform secret manager.

# Public
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_123

# Server
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
STRIPE_SECRET_KEY=sk_test_123
STRIPE_WEBHOOK_SECRET=whsec_staging_123
OPENAI_API_KEY=sk-staging-placeholder
OPENAI_MODEL=gpt-4.1-mini

# Automation
AUTOMATION_CRON_SECRET=replace-with-strong-random-secret
CRON_SECRET=replace-with-strong-random-secret

# Optional outbound providers
RESEND_API_KEY=re_staging_123
OUTBOUND_EMAIL_FROM=Smile Transformation Staging <noreply-staging@your-domain.com>
OUTBOUND_WHATSAPP_API_URL=https://api.staging-whatsapp-provider.com/send
OUTBOUND_WHATSAPP_API_TOKEN=staging-whatsapp-token

# Optional metadata and infra
COMMIT_SHA=staging-build
RATE_LIMIT_PROVIDER=upstash
UPSTASH_REDIS_REST_URL=https://your-staging-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-staging-upstash-token
